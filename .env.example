# ── Application ─────────────────────────────────────
APP_NAME="Knowledge Assistant"
APP_ENV="development"           # development | production
DEBUG=true
SECRET_KEY="change-this-to-a-long-random-string-in-production"
ALLOWED_ORIGINS="http://localhost:3000,http://localhost:8000"

# ── Database ─────────────────────────────────────────
DATABASE_URL="postgresql+asyncpg://postgres:postgres@localhost:5432/knowledge_assistant"

# ── Redis ─────────────────────────────────────────────
REDIS_URL="redis://localhost:6379/0"

# ── Auth ──────────────────────────────────────────────
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── File Storage ──────────────────────────────────────
STORAGE_BACKEND="local"         # local | s3
LOCAL_UPLOAD_DIR="uploads"
MAX_UPLOAD_SIZE_MB=50

# ── RAG — Provider Selection ──────────────────────────
EMBEDDER_PROVIDER="openai"      # openai | huggingface | cohere
EMBEDDER_MODEL="text-embedding-3-small"

LLM_PROVIDER="openai"           # openai | anthropic | ollama
LLM_MODEL="gpt-4o-mini"

RERANKER_PROVIDER="flashrank"   # flashrank | cohere

# ── API Keys (leave blank if using local models) ──────
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
COHERE_API_KEY=""

# ── Ollama (for local models) ─────────────────────────
OLLAMA_BASE_URL="http://localhost:11434"

# ── Celery ────────────────────────────────────────────
CELERY_BROKER_URL="redis://localhost:6379/1"
CELERY_RESULT_BACKEND="redis://localhost:6379/2"